# --- NetDocs backend configuration (12-factor; see PRD §17) ---

# Database
DATABASE_URL=postgresql+asyncpg://netdocs:netdocs@localhost:5432/netdocs

# Redis (rate limit, cache, refresh-token denylist)
REDIS_URL=redis://localhost:6379/0

# JWT signing. In dev we use HS256 + a shared secret. For prod, supply
# RS256 keys (JWT_PRIVATE_KEY/JWT_PUBLIC_KEY) and set JWT_ALGORITHM=RS256.
JWT_ALGORITHM=HS256
JWT_SECRET=change-me-in-production-please-use-a-long-random-value
JWT_KID=dev-1
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# Key rotation (FR-40): JSON map of {kid: key} for verification + the active signing kid.
# Overlap old+new during rotation so live sessions keep validating.
# JWT_KEYS={"dev-1":"old-secret","dev-2":"new-secret"}
# JWT_ACTIVE_KID=dev-2
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Uploads / attachments (M5)
UPLOAD_DIR=/data/attachments
MAX_UPLOAD_MB=25
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain,application/json,application/octet-stream
# Block download until the AV worker marks the file clean.
ATTACHMENT_REQUIRE_CLEAN=true

# ClamAV (M5). When disabled, uploads are marked clean immediately (dev).
CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Rate limiting (M6, Redis-backed)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_IP=5
RATE_LIMIT_LOGIN_ACCOUNT=10
RATE_LIMIT_WRITE_USER=60
RATE_LIMIT_WINDOW_SECONDS=60

# Security headers (defense-in-depth; primary headers also set at the reverse proxy)
SECURITY_HEADERS_ENABLED=true

# First-run bootstrap admin (PRD §17). Created on first boot with
# must_change_password=true. Leave blank to skip bootstrap.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!456

# Auth hardening
PASSWORD_MIN_LENGTH=12
MAX_FAILED_LOGINS=10
LOCKOUT_MINUTES=15

ENVIRONMENT=dev
